{
  "name": "llm-stream-parser",
  "version": "0.1.0",
  "description": "Parse Server-Sent Events streams from OpenAI / Anthropic / compatible LLM APIs. Incremental SSE parser plus provider-specific text extractors. Zero dependencies.",
  "keywords": ["llm", "sse", "stream", "openai", "anthropic", "parser"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18" },
  "author": { "name": "Vlad Bordei", "email": "bordeivlad@gmail.com", "url": "https://github.com/p-vbordei" },
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/p-vbordei/llm-stream-parser.git" },
  "bugs": { "url": "https://github.com/p-vbordei/llm-stream-parser/issues" },
  "homepage": "https://github.com/p-vbordei/llm-stream-parser#readme",
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.0.0" }
}
